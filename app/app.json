{
  "expo": {
    "name": "StickDeath Infinity",
    "slug": "stickdeath-infinity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "stickdeath",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.stickdeath.infinity",
      "buildNumber": "1",
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"]
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Used to capture reference photos for animations",
        "NSPhotoLibraryUsageDescription": "Used to import images into your animation projects",
        "NSMicrophoneUsageDescription": "Used to record audio for your animations"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.stickdeath.infinity",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ff2d55"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.0",
            "usesAppleSignIn": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "EAS_PROJECT_ID_HERE"
      },
      "router": {
        "origin": false
      }
    }
  }
}
